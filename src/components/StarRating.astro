---
interface Props {
  /** Score out of 10. */
  score: number;
  size?: number;
  showNumber?: boolean;
}
const { score, size = 16, showNumber = false } = Astro.props;
const pct = Math.max(0, Math.min(100, (score / 10) * 100));
---

<span class="inline-flex items-center gap-1.5" role="img" aria-label={`${score} out of 10`}>
  <span class="relative inline-block select-none leading-none" style={`font-size:${size}px`} aria-hidden="true">
    <span class="tracking-[0.12em] text-ink-200">★★★★★</span>
    <span
      class="absolute inset-0 overflow-hidden whitespace-nowrap tracking-[0.12em] text-brand-400"
      style={`width:${pct}%`}
    >★★★★★</span>
  </span>
  {showNumber && <span class="text-sm font-bold text-ink-700">{score.toFixed(1)}</span>}
</span>
