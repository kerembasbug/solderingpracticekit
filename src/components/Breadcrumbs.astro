---
interface Props {
  items: { name: string; url: string }[];
}
const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="text-sm">
  <ol class="flex flex-wrap items-center gap-1.5 text-ink-400">
    {
      items.map((item, i) => (
        <li class="flex items-center gap-1.5">
          {i > 0 && (
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" class="text-ink-300">
              <path d="M9 18l6-6-6-6" />
            </svg>
          )}
          {i < items.length - 1 ? (
            <a href={item.url} class="transition-colors hover:text-brand-600">{item.name}</a>
          ) : (
            <span class="font-medium text-ink-600" aria-current="page">{item.name}</span>
          )}
        </li>
      ))
    }
  </ol>
</nav>
