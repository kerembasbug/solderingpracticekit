---
interface Props {
  pros: string[];
  cons: string[];
}
const { pros, cons } = Astro.props;
---

<div class="grid gap-4 sm:grid-cols-2">
  <div class="rounded-2xl border border-emerald-200 bg-emerald-50/60 p-5">
    <h3 class="flex items-center gap-2 text-sm font-bold uppercase tracking-wide text-emerald-700">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5" /></svg>
      Pros
    </h3>
    <ul class="mt-3 space-y-2.5">
      {
        pros.map((pro) => (
          <li class="flex items-start gap-2.5 text-sm leading-relaxed text-ink-700">
            <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-emerald-500" />
            <span>{pro}</span>
          </li>
        ))
      }
    </ul>
  </div>
  <div class="rounded-2xl border border-rose-200 bg-rose-50/50 p-5">
    <h3 class="flex items-center gap-2 text-sm font-bold uppercase tracking-wide text-rose-600">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6L6 18M6 6l12 12" /></svg>
      Cons
    </h3>
    <ul class="mt-3 space-y-2.5">
      {
        cons.map((con) => (
          <li class="flex items-start gap-2.5 text-sm leading-relaxed text-ink-700">
            <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-rose-400" />
            <span>{con}</span>
          </li>
        ))
      }
    </ul>
  </div>
</div>
