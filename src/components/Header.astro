---
import { SITE, NAV } from '@/config/site';

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) => pathname === href || pathname.startsWith(href + '/');
---

<header class="sticky top-0 z-50 border-b border-ink-200 bg-white/90 backdrop-blur supports-[backdrop-filter]:bg-white/75">
  <div class="container-px flex h-16 items-center justify-between gap-4">
    <a href="/" class="group flex items-center gap-2.5" aria-label={`${SITE.name} home`}>
      <span class="grid h-9 w-9 place-items-center rounded-lg bg-brand-500 text-white shadow-sm transition-transform group-hover:scale-105">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 21l4-1 11-11-3-3L4 17l-1 4z" />
          <path d="M14 6l3 3" />
          <path d="M18 3l3 3" />
        </svg>
      </span>
      <span class="text-[1.05rem] font-extrabold tracking-tight text-ink-900">
        Soldering<span class="text-brand-500">Practice</span>Kit
      </span>
    </a>

    <nav class="hidden items-center gap-1 md:flex" aria-label="Primary">
      {
        NAV.map((item) => (
          <a
            href={item.href}
            class:list={[
              'rounded-md px-3 py-2 text-sm font-semibold transition-colors',
              isActive(item.href)
                ? 'text-brand-600'
                : 'text-ink-600 hover:text-ink-900 hover:bg-ink-100',
            ]}
            aria-current={isActive(item.href) ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))
      }
      <a
        href="/best-soldering-practice-kits"
        class="ml-2 rounded-md bg-ink-900 px-3.5 py-2 text-sm font-bold text-white transition-colors hover:bg-ink-800"
      >
        Top Picks
      </a>
    </nav>

    <!-- Mobile menu (no-JS, uses <details>) -->
    <details class="relative md:hidden">
      <summary
        class="grid h-10 w-10 cursor-pointer list-none place-items-center rounded-md text-ink-700 hover:bg-ink-100 [&::-webkit-details-marker]:hidden"
        aria-label="Open menu"
      >
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <path d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </summary>
      <div class="absolute right-0 mt-2 w-56 overflow-hidden rounded-xl border border-ink-200 bg-white py-2 shadow-lg">
        {
          NAV.map((item) => (
            <a href={item.href} class="block px-4 py-2.5 text-sm font-semibold text-ink-700 hover:bg-ink-50 hover:text-brand-600">
              {item.label}
            </a>
          ))
        }
        <a href="/best-soldering-practice-kits" class="mt-1 block border-t border-ink-100 px-4 py-2.5 text-sm font-bold text-brand-600 hover:bg-ink-50">
          → Top Picks
        </a>
      </div>
    </details>
  </div>
</header>
