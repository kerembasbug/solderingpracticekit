# ---------------------------------------------------------------------------
# Copy to .env for local development. In Coolify, set these as environment /
# build variables instead. NEVER commit real keys.
# ---------------------------------------------------------------------------

# Canonical site URL (no trailing slash). Used for SEO, canonical tags, sitemap.
SITE_URL=https://solderingpracticekit.com

# Amazon Associates tracking id (REQUIRED to earn commissions). This is public.
AMAZON_PARTNER_TAG=revoba-20

# Amazon Product Advertising API 5.0 credentials (OPTIONAL).
# Leave blank to build from curated data (shows "Check price on Amazon").
# Add them once your Associates account has PA-API access to get LIVE prices.
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=

# US marketplace defaults — change only for a different Amazon locale.
AMAZON_HOST=webservices.amazon.com
AMAZON_REGION=us-east-1
AMAZON_MARKETPLACE=www.amazon.com
AMAZON_STOREFRONT=amazon.com

# Contact address shown on the site.
CONTACT_EMAIL=hello@solderingpracticekit.com
