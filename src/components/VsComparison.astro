---
import type { Product } from '@/lib/types';
import StarRating from '@/components/StarRating.astro';
import AffiliateButton from '@/components/AffiliateButton.astro';

interface Props {
  a: Product;
  b: Product;
}
const { a, b } = Astro.props;

const cards: Product[] = [a, b];
---

<div class="relative grid gap-6 md:grid-cols-2">
  <!-- Centre VS badge (desktop) -->
  <div
    class="pointer-events-none absolute left-1/2 top-1/2 z-10 hidden -translate-x-1/2 -translate-y-1/2 md:block"
    aria-hidden="true"
  >
    <span class="grid h-12 w-12 place-items-center rounded-full border-2 border-white bg-ink-900 text-sm font-extrabold text-white shadow-lg">
      VS
    </span>
  </div>

  {
    cards.map((p) => (
      <article class="flex flex-col rounded-2xl border border-ink-200 bg-white p-6 shadow-[var(--shadow-card)]">
        {p.award && (
          <span class="mb-3 inline-block w-fit rounded-full bg-brand-500 px-3 py-1 text-xs font-bold text-white">
            {p.award}
          </span>
        )}
        <a href={`/reviews/${p.slug}`} class="block aspect-square overflow-hidden rounded-xl border border-ink-100 bg-white p-4">
          <img
            src={p.image}
            alt={p.fullTitle}
            width={p.imageWidth}
            height={p.imageHeight}
            loading="lazy"
            decoding="async"
            class="h-full w-full object-contain"
          />
        </a>
        <p class="mt-4 text-xs font-semibold uppercase tracking-wide text-ink-400">{p.brand}</p>
        <h3 class="mt-1 text-xl font-bold leading-snug text-ink-900">
          <a href={`/reviews/${p.slug}`} class="hover:text-brand-600">{p.title}</a>
        </h3>
        <div class="mt-2 flex items-center gap-2">
          <StarRating score={p.ourScore} />
          <span class="font-bold text-ink-800">{p.ourScore.toFixed(1)}</span>
          <span class="text-sm text-ink-400">/ 10</span>
        </div>
        <p class="mt-3 flex-1 text-sm leading-relaxed text-ink-600">{p.tagline}</p>

        <dl class="mt-4 space-y-2 border-t border-ink-100 pt-4 text-sm">
          <div class="flex justify-between gap-3">
            <dt class="text-ink-400">Best for</dt>
            <dd class="text-right font-medium text-ink-700">{p.bestFor}</dd>
          </div>
          <div class="flex justify-between gap-3">
            <dt class="text-ink-400">Price tier</dt>
            <dd class="text-right font-medium text-ink-700">{p.priceTier}</dd>
          </div>
        </dl>

        <div class="mt-5">
          <AffiliateButton product={p} fullWidth />
        </div>
        <a href={`/reviews/${p.slug}`} class="mt-3 block text-center text-sm font-semibold text-brand-600 hover:text-brand-700">
          Read full review →
        </a>
      </article>
    ))
  }
</div>

<!-- Feature face-off -->
<div class="mt-8 grid gap-6 sm:grid-cols-2">
  {
    cards.map((p) => (
      <div class="rounded-2xl border border-ink-200 bg-ink-50/40 p-6">
        <h4 class="text-sm font-bold uppercase tracking-wide text-ink-500">{p.title}</h4>
        <ul class="mt-4 space-y-2.5">
          {p.features.map((f) => (
            <li class="flex items-start gap-2.5 text-sm text-ink-700">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="mt-0.5 shrink-0 text-brand-500">
                <path d="M20 6L9 17l-5-5" />
              </svg>
              <span>{f}</span>
            </li>
          ))}
        </ul>
      </div>
    ))
  }
</div>
