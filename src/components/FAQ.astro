---
interface Props {
  faqs: { question: string; answer: string }[];
  title?: string;
}
const { faqs, title = 'Frequently asked questions' } = Astro.props;
---

<section class="mx-auto max-w-3xl">
  <h2 class="text-2xl font-extrabold tracking-tight text-ink-900 sm:text-3xl">{title}</h2>
  <div class="mt-6 divide-y divide-ink-200 rounded-2xl border border-ink-200 bg-white">
    {
      faqs.map((faq) => (
        <details class="group px-5 py-1 [&_summary::-webkit-details-marker]:hidden">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 py-4 text-left font-semibold text-ink-800">
            <span>{faq.question}</span>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true" class="shrink-0 text-brand-500 transition-transform group-open:rotate-180">
              <path d="M6 9l6 6 6-6" />
            </svg>
          </summary>
          <div class="pb-5 pr-8 text-[0.95rem] leading-relaxed text-ink-600" set:html={faq.answer} />
        </details>
      ))
    }
  </div>
</section>
