---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import { breadcrumbSchema, jsonLdGraph } from '@/lib/seo';

const guides = (await getCollection('guides', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

const featured = guides.find((g) => g.data.featured) ?? guides[0];
const rest = guides.filter((g) => g.id !== featured?.id);

const crumbs = [
  { name: 'Home', url: '/' },
  { name: 'Guides', url: '/guides' },
];
const jsonLd = jsonLdGraph(breadcrumbSchema(crumbs));

const dateFmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<BaseLayout
  title="Soldering Guides & How-Tos"
  description="Learn to solder with clear, beginner-friendly guides — from your first joint to surface-mount technique, choosing an iron, safety and troubleshooting."
  jsonLd={jsonLd}
>
  <div class="container-px py-8 lg:py-12">
    <Breadcrumbs items={crumbs} />
    <header class="mt-6 max-w-3xl">
      <h1 class="text-4xl font-extrabold tracking-tight text-ink-900 sm:text-5xl">Soldering guides</h1>
      <p class="mt-4 text-lg leading-relaxed text-ink-600">
        Everything you need to go from nervous beginner to confident solderer — written in plain
        English, with the practice kits to try each skill on.
      </p>
    </header>

    {
      featured && (
        <a href={`/guides/${featured.id}`} class="group mt-10 block overflow-hidden rounded-3xl border border-ink-200 bg-gradient-to-br from-ink-900 to-ink-800 p-8 text-white lg:p-12">
          <span class="text-xs font-bold uppercase tracking-wide text-brand-300">{featured.data.category} · Featured</span>
          <h2 class="mt-3 max-w-2xl text-3xl font-extrabold leading-tight tracking-tight group-hover:text-brand-100 lg:text-4xl">
            {featured.data.title}
          </h2>
          <p class="mt-4 max-w-2xl text-ink-200">{featured.data.description}</p>
          <span class="mt-6 inline-block font-semibold text-brand-300">Read the guide →</span>
        </a>
      )
    }

    <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        rest.map((g) => (
          <a href={`/guides/${g.id}`} class="group flex flex-col overflow-hidden rounded-2xl border border-ink-200 bg-white transition-shadow hover:shadow-[var(--shadow-card)]">
            {g.data.heroImage && (
              <div class="aspect-video overflow-hidden bg-ink-100">
                <img
                  src={g.data.heroImage}
                  alt={g.data.title}
                  width={640}
                  height={360}
                  loading="lazy"
                  decoding="async"
                  class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                />
              </div>
            )}
            <div class="flex flex-1 flex-col p-6">
              <div class="flex items-center justify-between">
                <span class="text-xs font-bold uppercase tracking-wide text-brand-600">{g.data.category}</span>
                <span class="text-xs text-ink-400">{dateFmt(g.data.pubDate)}</span>
              </div>
              <h3 class="mt-3 text-lg font-bold leading-snug text-ink-900 group-hover:text-brand-700">{g.data.title}</h3>
              <p class="mt-2 flex-1 text-sm leading-relaxed text-ink-600">{g.data.description}</p>
              <span class="mt-4 text-sm font-semibold text-brand-600">Read guide →</span>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</BaseLayout>
