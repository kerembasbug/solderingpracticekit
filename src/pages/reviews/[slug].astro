---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import AffiliateButton from '@/components/AffiliateButton.astro';
import AffiliateDisclosure from '@/components/AffiliateDisclosure.astro';
import ProsCons from '@/components/ProsCons.astro';
import ProductCard from '@/components/ProductCard.astro';
import StarRating from '@/components/StarRating.astro';
import { getProducts } from '@/lib/products';
import type { Product } from '@/lib/types';
import { productSchema, breadcrumbSchema, jsonLdGraph } from '@/lib/seo';

export const getStaticPaths = (async () => {
  const products = await getProducts();
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}) satisfies GetStaticPaths;

interface Props {
  product: Product;
}
const { product } = Astro.props;
const all = await getProducts();
const related = all
  .filter((p) => p.category === product.category && p.slug !== product.slug)
  .slice(0, 3);

const categoryLabel =
  product.category === 'tool'
    ? 'Soldering Irons & Tools'
    : product.category === 'project'
      ? 'Project Kits'
      : 'Practice Kits';
const categoryUrl =
  product.category === 'tool'
    ? '/best-soldering-irons'
    : product.category === 'project'
      ? '/best-soldering-project-kits'
      : '/best-soldering-practice-kits';

const crumbs = [
  { name: 'Home', url: '/' },
  { name: 'Reviews', url: '/reviews' },
  { name: product.title, url: `/reviews/${product.slug}` },
];

const jsonLd = jsonLdGraph(productSchema(product), breadcrumbSchema(crumbs));

// SEO <title> carries a year for freshness and to differ from the on-page H1
// (`${product.title} Review`), avoiding the duplicate H1/title warning.
const reviewYear = new Date(`${product.updatedAt}T00:00:00Z`).getUTCFullYear();
const seoTitle = `${product.title} Review (${reviewYear})`;
---

<BaseLayout
  title={seoTitle}
  description={product.excerpt}
  image={product.image}
  type="article"
  jsonLd={jsonLd}
  modifiedTime={`${product.updatedAt}T00:00:00Z`}
>
  <div class="container-px py-8 lg:py-12">
    <Breadcrumbs items={crumbs} />

    <div class="mt-8 grid gap-10 lg:grid-cols-[minmax(0,1fr)_360px]">
      <!-- Main -->
      <div>
        <div class="flex flex-wrap items-center gap-3">
          <a href={categoryUrl} class="text-xs font-bold uppercase tracking-wide text-brand-600 hover:text-brand-700">{categoryLabel}</a>
          {product.award && <span class="rounded-full bg-brand-500 px-3 py-1 text-xs font-bold text-white">{product.award}</span>}
        </div>
        <h1 class="mt-3 text-3xl font-extrabold leading-tight tracking-tight text-ink-900 sm:text-4xl">
          {product.title} Review
        </h1>
        <p class="mt-2 text-sm text-ink-400">By {product.brand} · Updated {product.updatedAt}</p>

        <div class="mt-4 flex items-center gap-3">
          <StarRating score={product.ourScore} size={20} />
          <span class="text-lg font-extrabold text-ink-900">{product.ourScore.toFixed(1)}</span>
          <span class="text-sm text-ink-400">/ 10 · our score</span>
        </div>

        <p class="mt-6 text-lg leading-relaxed text-ink-700">{product.excerpt}</p>

        <div class="mt-6 lg:hidden">
          <AffiliateButton product={product} fullWidth size="lg" showTimestamp={false} />
        </div>

        <div class="mt-8">
          <h2 class="text-xl font-bold text-ink-900">Our verdict</h2>
          <p class="mt-3 leading-relaxed text-ink-600">{product.verdict}</p>
        </div>

        <div class="mt-8">
          <h2 class="mb-4 text-xl font-bold text-ink-900">Pros & cons</h2>
          <ProsCons pros={product.pros} cons={product.cons} />
        </div>

        <div class="mt-6">
          <AffiliateButton product={product} fullWidth size="lg" />
        </div>

        <div class="mt-8 rounded-2xl border border-ink-200 bg-white p-6">
          <h2 class="text-xl font-bold text-ink-900">Key features</h2>
          <ul class="mt-4 grid gap-3 sm:grid-cols-2">
            {
              product.features.map((f) => (
                <li class="flex items-start gap-2.5 text-sm text-ink-700">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="mt-0.5 shrink-0 text-brand-500"><path d="M20 6L9 17l-5-5" /></svg>
                  <span>{f}</span>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="mt-8 rounded-2xl bg-ink-900 p-6 text-white">
          <h2 class="text-lg font-bold">Who it's for</h2>
          <p class="mt-2 text-ink-200">{product.bestFor}</p>
        </div>
      </div>

      <!-- Sticky buy box -->
      <aside class="lg:sticky lg:top-24 lg:h-fit">
        <div class="rounded-2xl border border-ink-200 bg-white p-6 shadow-[var(--shadow-card)]">
          <div class="aspect-square overflow-hidden rounded-xl border border-ink-100 bg-white p-4">
            <img src={product.image} alt={product.fullTitle} width={product.imageWidth} height={product.imageHeight} fetchpriority="high" decoding="async" class="h-full w-full object-contain" />
          </div>
          <h2 class="mt-4 text-base font-bold leading-snug text-ink-900">{product.title}</h2>
          <div class="mt-2 flex items-center gap-2">
            <StarRating score={product.ourScore} />
            <span class="text-sm font-bold text-ink-700">{product.ourScore.toFixed(1)} / 10</span>
          </div>
          {
            product.live?.price && (
              <p class="mt-3 text-2xl font-extrabold text-ink-900">{product.live.price}</p>
            )
          }
          <div class="mt-4">
            <AffiliateButton product={product} fullWidth size="lg" />
          </div>
          <div class="mt-4">
            <AffiliateDisclosure variant="inline" />
          </div>
        </div>
      </aside>
    </div>

    <!-- Related -->
    {
      related.length > 0 && (
        <section class="mt-16">
          <h2 class="text-2xl font-extrabold tracking-tight text-ink-900">You might also like</h2>
          <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {related.map((p) => <ProductCard product={p} />)}
          </div>
        </section>
      )
    }

    <!-- Helpful guides (cross-links the guides silo) -->
    <section class="mt-16 rounded-3xl border border-ink-200 bg-white p-6 lg:p-8">
      <h2 class="text-2xl font-extrabold tracking-tight text-ink-900">New to soldering? Start here</h2>
      <div class="mt-6 grid gap-4 sm:grid-cols-3">
        {
          [
            { href: '/guides/how-to-solder-for-beginners', cat: 'Beginner Guide', title: 'How to Solder for Beginners' },
            { href: '/guides/how-to-choose-a-soldering-iron', cat: 'Buying Guide', title: 'How to Choose a Soldering Iron' },
            { href: '/guides/common-soldering-mistakes', cat: 'Troubleshooting', title: '10 Common Soldering Mistakes' },
          ].map((g) => (
            <a href={g.href} class="group flex flex-col rounded-2xl border border-ink-200 bg-ink-50/40 p-5 transition-shadow hover:shadow-[var(--shadow-card)]">
              <span class="text-xs font-bold uppercase tracking-wide text-brand-600">{g.cat}</span>
              <h3 class="mt-2 flex-1 text-base font-bold leading-snug text-ink-900 group-hover:text-brand-700">{g.title}</h3>
              <span class="mt-3 text-sm font-semibold text-brand-600">Read guide →</span>
            </a>
          ))
        }
      </div>
    </section>
  </div>
</BaseLayout>
