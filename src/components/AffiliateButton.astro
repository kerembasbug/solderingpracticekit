---
import type { Product } from '@/lib/types';
import { affiliateUrl } from '@/lib/amazon/links';

interface Props {
  product: Product;
  /** Override the button label. */
  label?: string;
  size?: 'sm' | 'md' | 'lg';
  fullWidth?: boolean;
  /** Show the "Price as of …" line under live prices. */
  showTimestamp?: boolean;
}

const { product, label, size = 'md', fullWidth = false, showTimestamp = true } = Astro.props;
const href = affiliateUrl(product.asin);
const live = product.live;
const text = label ?? (live?.price ? `${live.price} — View on Amazon` : 'Check Price on Amazon');

const pad = size === 'lg' ? 'px-6 py-3.5 text-base' : size === 'sm' ? 'px-3.5 py-2 text-sm' : 'px-5 py-3 text-[0.95rem]';

const asOf = live?.fetchedAt
  ? new Date(live.fetchedAt).toLocaleString('en-US', {
      month: 'short',
      day: 'numeric',
      year: 'numeric',
      hour: 'numeric',
      minute: '2-digit',
    })
  : null;
---

<div class:list={[fullWidth ? 'w-full' : 'inline-block']}>
  <a
    href={href}
    target="_blank"
    rel="sponsored nofollow noopener"
    class:list={[
      'btn-buy hover:btn-buy-hover active:scale-[0.99]',
      pad,
      fullWidth && 'w-full',
    ]}
  >
    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="9" cy="21" r="1" /><circle cx="20" cy="21" r="1" />
      <path d="M1 1h4l2.7 13.4a2 2 0 0 0 2 1.6h9.7a2 2 0 0 0 2-1.6L23 6H6" />
    </svg>
    <span>{text}</span>
  </a>
  {
    showTimestamp && asOf && (
      <p class="mt-1.5 text-center text-[0.7rem] leading-tight text-ink-400">
        Price as of {asOf}. {live?.isPrimeEligible ? 'Prime eligible. ' : ''}Details on Amazon.
      </p>
    )
  }
  {
    showTimestamp && !asOf && (
      <p class="mt-1.5 text-center text-[0.7rem] leading-tight text-ink-400">
        We earn a commission, at no extra cost to you.
      </p>
    )
  }
</div>
