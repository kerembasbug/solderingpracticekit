---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import { SITE } from '@/config/site';
import { breadcrumbSchema, jsonLdGraph } from '@/lib/seo';

const crumbs = [
  { name: 'Home', url: '/' },
  { name: 'Contact', url: '/contact' },
];
const jsonLd = jsonLdGraph(breadcrumbSchema(crumbs));
---

<BaseLayout
  title="Contact"
  description={`Get in touch with the ${SITE.name} team — questions, corrections, feedback and partnership enquiries.`}
  jsonLd={jsonLd}
>
  <div class="container-px py-8 lg:py-12">
    <Breadcrumbs items={crumbs} />
    <div class="mx-auto mt-8 max-w-2xl">
      <h1 class="text-4xl font-extrabold tracking-tight text-ink-900">Contact us</h1>
      <p class="mt-4 text-lg leading-relaxed text-ink-600">
        Questions, corrections, or a kit you'd like us to review? We read every message.
      </p>

      <div class="mt-8 rounded-2xl border border-ink-200 bg-white p-6">
        <p class="text-sm font-semibold uppercase tracking-wide text-ink-400">Email</p>
        <a href={`mailto:${SITE.contactEmail}`} class="mt-1 block text-xl font-bold text-brand-600 hover:text-brand-700">
          {SITE.contactEmail}
        </a>
        <p class="mt-4 text-sm leading-relaxed text-ink-500">
          We typically reply within a couple of business days. For corrections, please include the
          page URL and what needs fixing so we can get to it quickly.
        </p>
      </div>

      <div class="mt-6 rounded-2xl border border-ink-200 bg-ink-50/50 p-6 text-sm leading-relaxed text-ink-600">
        <p>
          <strong class="text-ink-800">A note on product questions:</strong> we're a review site, not
          a retailer. For order, shipping or warranty questions about a specific product, please
          contact the seller or Amazon directly.
        </p>
      </div>

      <div class="prose mt-10 max-w-none text-ink-600">
        <h2>What to include in your message</h2>
        <p>
          To help us reply quickly and usefully, please give us a little context. If you're writing
          about a specific kit or tool, include the product name and, where relevant, the page on our
          site you're referring to. If you've spotted an error — a wrong spec, a broken link, an
          out-of-date detail — a quick note of the exact page URL and what looks off lets us verify
          and fix it fast. The more specific you are, the faster we can act.
        </p>

        <h2>What we can help with</h2>
        <ul>
          <li><strong>Corrections and updates</strong> — tell us if something on a review or guide looks wrong or outdated.</li>
          <li><strong>Kit suggestions</strong> — recommend a soldering practice kit or tool you think we should test and rank.</li>
          <li><strong>Feedback</strong> — let us know what's helpful, what's confusing, or what you'd like us to cover next.</li>
          <li><strong>Guide requests</strong> — stuck on a soldering problem we haven't written about? Tell us, and it may become our next how-to.</li>
          <li><strong>Partnerships and press</strong> — reach out about collaborations or media enquiries.</li>
        </ul>

        <h2>Response time</h2>
        <p>
          We're a small, independent team, so we read every message but can't always reply
          instantly. In most cases you'll hear back within two to three business days. If your
          message is a correction to published content, we usually review it sooner because accuracy
          matters to us — our recommendations are only as good as the trust behind them.
        </p>

        <h2>Before you write</h2>
        <p>
          Many common questions are already answered in our <a href="/guides">soldering guides</a> —
          from <a href="/guides/how-to-solder-for-beginners">how to solder for beginners</a> to
          <a href="/guides/how-to-choose-a-soldering-iron">choosing the right iron</a>. If you're
          looking for a recommendation, our <a href="/best-soldering-practice-kits">best soldering
          practice kits</a> roundup is the fastest place to start. For anything else, the email above
          is the best way to reach us.
        </p>
      </div>
    </div>
  </div>
</BaseLayout>
