---
import type { Product } from '@/lib/types';
import StarRating from '@/components/StarRating.astro';
import AffiliateButton from '@/components/AffiliateButton.astro';

interface Props {
  product: Product;
  /** Show a numeric rank chip (for roundups). */
  showRank?: boolean;
  rank?: number;
}
const { product, showRank = false, rank } = Astro.props;
const reviewHref = `/reviews/${product.slug}`;
const displayRank = rank ?? product.rank;
---

<article class="group relative flex flex-col overflow-hidden rounded-2xl border border-ink-200 bg-white shadow-[var(--shadow-card)] transition-shadow hover:shadow-[var(--shadow-card-hover)]">
  {
    product.award && (
      <span class="absolute left-0 top-4 z-10 rounded-r-full bg-brand-500 py-1 pl-3 pr-3.5 text-xs font-bold text-white shadow-sm">
        {product.award}
      </span>
    )
  }
  {
    showRank && (
      <span class="absolute right-3 top-3 z-10 grid h-8 w-8 place-items-center rounded-full bg-ink-900 text-sm font-extrabold text-white">
        {displayRank}
      </span>
    )
  }

  <a href={reviewHref} class="block bg-white p-5" aria-label={`Read our ${product.title} review`}>
    <div class="aspect-square w-full overflow-hidden rounded-lg bg-white">
      <img
        src={product.image}
        alt={product.fullTitle}
        width={product.imageWidth}
        height={product.imageHeight}
        loading="lazy"
        decoding="async"
        class="h-full w-full object-contain transition-transform duration-300 group-hover:scale-105"
      />
    </div>
  </a>

  <div class="flex flex-1 flex-col px-5 pb-5">
    <p class="text-xs font-semibold uppercase tracking-wide text-ink-400">{product.brand}</p>
    <h3 class="mt-1 text-base font-bold leading-snug text-ink-900">
      <a href={reviewHref} class="hover:text-brand-600">{product.title}</a>
    </h3>

    <div class="mt-2 flex items-center gap-2">
      <StarRating score={product.ourScore} />
      <span class="text-sm font-bold text-ink-700">{product.ourScore.toFixed(1)}</span>
      <span class="text-xs text-ink-400">/ 10</span>
    </div>

    <p class="mt-3 flex-1 text-sm leading-relaxed text-ink-600">{product.tagline}</p>

    <div class="mt-4 space-y-3">
      <AffiliateButton product={product} fullWidth size="sm" />
      <a href={reviewHref} class="block text-center text-sm font-semibold text-brand-600 hover:text-brand-700">
        Read full review →
      </a>
    </div>
  </div>
</article>
