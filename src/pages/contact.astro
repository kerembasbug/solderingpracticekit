---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import { SITE } from '@/config/site';
import { breadcrumbSchema, jsonLdGraph } from '@/lib/seo';

const crumbs = [
  { name: 'Home', url: '/' },
  { name: 'Contact', url: '/contact' },
];
const jsonLd = jsonLdGraph(breadcrumbSchema(crumbs));
---

<BaseLayout
  title="Contact"
  description={`Get in touch with the ${SITE.name} team — questions, corrections, feedback and partnership enquiries.`}
  jsonLd={jsonLd}
>
  <div class="container-px py-8 lg:py-12">
    <Breadcrumbs items={crumbs} />
    <div class="mx-auto mt-8 max-w-2xl">
      <h1 class="text-4xl font-extrabold tracking-tight text-ink-900">Contact us</h1>
      <p class="mt-4 text-lg leading-relaxed text-ink-600">
        Questions, corrections, or a kit you'd like us to review? We read every message.
      </p>

      <div class="mt-8 rounded-2xl border border-ink-200 bg-white p-6">
        <p class="text-sm font-semibold uppercase tracking-wide text-ink-400">Email</p>
        <a href={`mailto:${SITE.contactEmail}`} class="mt-1 block text-xl font-bold text-brand-600 hover:text-brand-700">
          {SITE.contactEmail}
        </a>
        <p class="mt-4 text-sm leading-relaxed text-ink-500">
          We typically reply within a couple of business days. For corrections, please include the
          page URL and what needs fixing so we can get to it quickly.
        </p>
      </div>

      <div class="mt-6 rounded-2xl border border-ink-200 bg-ink-50/50 p-6 text-sm leading-relaxed text-ink-600">
        <p>
          <strong class="text-ink-800">A note on product questions:</strong> we're a review site, not
          a retailer. For order, shipping or warranty questions about a specific product, please
          contact the seller or Amazon directly.
        </p>
      </div>
    </div>
  </div>
</BaseLayout>
